---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'WORK Launch Pad' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="WORK Launch Pad - Creative Venture Studio and Execution Launchpad" />
    <link rel="stylesheet" href="https://use.typekit.net/hyz5gvd.css" />
  </head>
  <body class="bg-paper text-ink">
    <div id="swup" class="transition-fade min-h-screen" data-swup-container>
      <header class="site-header">
        <a href="/" class="brand" data-transition-link>WORK Launch Pad</a>
        <nav>
          <ul class="nav-list">
            <li><a href="/about" data-transition-link data-flip-source="about-title" data-flip-key="about-title">About</a></li>
            <li><a href="/model" data-transition-link>Model</a></li>
            <li><a href="/ventures" data-transition-link>Ventures</a></li>
            <li><a href="/contact" data-transition-link>Contact</a></li>
          </ul>
        </nav>
      </header>
      <main>
        <slot />
      </main>
    </div>
    <script type="module">
      import '../lib/boot.ts';
    </script>
  </body>
</html>

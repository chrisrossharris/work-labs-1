---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'WORK Labs' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="WORK Labs - execution arm for brand systems, launches, and growth operations." />
    <link rel="stylesheet" href="https://use.typekit.net/hyz5gvd.css" />
  </head>
  <body class="bg-paper text-ink">
    <div id="swup" class="transition-fade min-h-screen" data-swup-container>
      <header class="site-header">
        <a href="/" class="brand" data-transition-link>WORK Labs</a>
        <nav>
          <ul class="nav-list">
            <li><a href="/about" data-transition-link data-flip-source="about-title" data-flip-key="about-title">About</a></li>
            <li><a href="/process" data-transition-link>Process</a></li>
            <li><a href="/model" data-transition-link>Offerings</a></li>
            <li><a href="/launchpad" data-transition-link>Launchpad Program</a></li>
            <li><a href="/work-hq" data-transition-link>WORK-HQ</a></li>
            <li><a href="/portfolio" data-transition-link>Portfolio</a></li>
            <li><a href="/contact" data-transition-link>Contact</a></li>
          </ul>
        </nav>
      </header>
      <main>
        <slot />
      </main>
    </div>
    <script>
      import '../lib/boot.ts';
    </script>
  </body>
</html>

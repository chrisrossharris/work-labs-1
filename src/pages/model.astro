---
import Base from '@/layouts/Base.astro';
import RevealText from '@/components/RevealText.astro';
---

<Base title="Model | WORK Launch Pad">
  <div class="section-shell">
    <section class="section-block">
      <div class="kicker"><span class="section-number">01 Model</span><span>Launch Pad Framework</span></div>
      <RevealText as="h1" variant="title" class="route-title">Launch Pad Model</RevealText>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">02 CI</span><span>Collaborative Intelligence</span></div>
      <RevealText as="p" variant="para" class="text-sm max-w-3xl">
        AI + HI = CI. AI accelerates synthesis and scenario testing. Human operators set standards, context, and judgment.
      </RevealText>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">03 Brand Engineering</span><span>Asset Logic</span></div>
      <RevealText as="p" variant="para" class="text-sm max-w-3xl">
        We architect positioning, offer systems, and narrative structures to increase valuation and strategic optionality.
      </RevealText>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">04 Execution Network</span><span>Hybrid Studio</span></div>
      <RevealText as="p" variant="para" class="text-sm max-w-3xl">
        Core operators plus WORK & Friends create elastic capacity without bloated fixed overhead.
      </RevealText>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">05 Equity Alignment</span><span>Upside Structures</span></div>
      <RevealText as="p" variant="para" class="text-sm max-w-3xl">
        Engagements are structured around retention, equity participation, royalties, and compound venture outcomes.
      </RevealText>
    </section>
  </div>
</Base>

---
import Base from '@/layouts/Base.astro';
import RevealText from '@/components/RevealText.astro';
---

<Base title="Library | WORK Labs">
  <div class="section-shell">
    <section class="section-block">
      <div class="kicker"><span class="section-number">01 Library</span><span>Organized Content Index</span></div>
      <RevealText as="h1" variant="title" class="route-title">WORK Library</RevealText>
      <RevealText as="p" variant="para" class="mt-5 max-w-3xl text-sm">
        A structured reference of Cabell's thinking, WORK's operating model, and the commercial framework behind launch and growth.
      </RevealText>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">02 Strategy</span><span>Thinking Frameworks</span></div>
      <div class="data-grid">
        <a class="data-cell" href="/launchpad" data-transition-link><p class="text-xs uppercase tracking-[0.12em] text-slate">Startup Program</p><h3 class="mt-2 text-base">WORK Launchpad</h3><p class="text-sm mt-2">20-min call, direction sprint, focused brand build, execution, ongoing oversight.</p></a>
        <a class="data-cell" href="/work-prism" data-transition-link><p class="text-xs uppercase tracking-[0.12em] text-slate">Retainer</p><h3 class="mt-2 text-base">WORK Prism</h3><p class="text-sm mt-2">Consultant services and system-thinking retainers for ongoing leadership support.</p></a>
        <a class="data-cell" href="/flex-consultant" data-transition-link><p class="text-xs uppercase tracking-[0.12em] text-slate">Lifecycle</p><h3 class="mt-2 text-base">Flex Consultant</h3><p class="text-sm mt-2">Critical-stage guidance across Ideation, Launch, Growth, Maturity, Transformation.</p></a>
      </div>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">03 Trust</span><span>Proof & Reputation</span></div>
      <div class="data-grid">
        <a class="data-cell" href="/testimonials" data-transition-link><p class="text-xs uppercase tracking-[0.12em] text-slate">Social Proof</p><h3 class="mt-2 text-base">Testimonials</h3><p class="text-sm mt-2">Industry leaders on Cabell's strategic and creative capability.</p></a>
        <a class="data-cell" href="/portfolio" data-transition-link><p class="text-xs uppercase tracking-[0.12em] text-slate">Execution</p><h3 class="mt-2 text-base">Portfolio</h3><p class="text-sm mt-2">Active examples of asset-oriented brand and product execution.</p></a>
        <a class="data-cell" href="/process" data-transition-link><p class="text-xs uppercase tracking-[0.12em] text-slate">Operations</p><h3 class="mt-2 text-base">Process</h3><p class="text-sm mt-2">Detailed pages covering experience, process, flexibility, and service structure.</p></a>
      </div>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">04 Commercial</span><span>Terms & Economics</span></div>
      <div class="data-grid">
        <a class="data-cell" href="/fees" data-transition-link><p class="text-xs uppercase tracking-[0.12em] text-slate">Terms</p><h3 class="mt-2 text-base">Fee Structure</h3><p class="text-sm mt-2">Simple terms, monthly structures, scope boundaries, and payment rules.</p></a>
        <a class="data-cell" href="/contact" data-transition-link><p class="text-xs uppercase tracking-[0.12em] text-slate">Action</p><h3 class="mt-2 text-base">Partner Inquiry</h3><p class="text-sm mt-2">Primary conversion path for founders, operators, and investment teams.</p></a>
      </div>
    </section>
  </div>
</Base>

---
import Base from '@/layouts/Base.astro';
import RevealText from '@/components/RevealText.astro';
import { getBookingLinkAttrs } from '@/data/booking';

const workPrismSiteUrl = 'https://workprism.com';
---

<Base title="WORK Prism | Consulting Retainers">
  <div class="section-shell">
    <section class="section-block">
      <div class="kicker"><span class="section-number">01 WORK Prism</span><span>Separate Consulting Track</span></div>
      <RevealText as="h1" variant="title" class="route-title workprism-title">Consultant Services + System Thinking Retainers</RevealText>
      <div class="workprism-hero-meta">
        <RevealText as="p" variant="para" class="text-sm max-w-xl">
          WORK Prism is the advisory-focused offer: senior consulting, system thinking, and recurring strategic leadership.
        </RevealText>
        <p class="text-xs uppercase tracking-[0.12em] text-slate">
          External Site:
          <a href={workPrismSiteUrl} target="_blank" rel="noopener noreferrer" class="underline">
            Visit WORK Prism ↗
          </a>
        </p>
      </div>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">02 What It Sells</span><span>Core Service Stack</span></div>
      <div class="data-grid">
        <article class="data-cell">
          <p class="text-xs uppercase tracking-[0.12em] text-slate">01</p>
          <h3 class="mt-2 text-base">System Thinking Retainer</h3>
          <p class="text-sm mt-2">Monthly strategic operating support for founders and leadership teams.</p>
        </article>
        <article class="data-cell">
          <p class="text-xs uppercase tracking-[0.12em] text-slate">02</p>
          <h3 class="mt-2 text-base">Consultant Services</h3>
          <p class="text-sm mt-2">Targeted consulting around positioning, growth decisions, and transformation.</p>
        </article>
        <article class="data-cell">
          <p class="text-xs uppercase tracking-[0.12em] text-slate">03</p>
          <h3 class="mt-2 text-base">Fractional Leadership</h3>
          <p class="text-sm mt-2">Embedded senior guidance without full-time overhead.</p>
        </article>
      </div>
    </section>

    <section class="section-block two-col">
      <div>
        <div class="kicker"><span class="section-number">03 Positioning</span><span>How It Differs</span></div>
        <RevealText as="p" variant="para" class="text-sm max-w-2xl">
          WORK Labs executes builds. WORK Launchpad runs startup launch programs. WORK Prism sells advisory retainers and consulting systems.
        </RevealText>
      </div>
      <div class="text-sm">
        <p class="uppercase tracking-[0.12em] text-slate">Primary Buyer</p>
        <p class="mt-3">Founder, operator, or leadership team needing recurring strategic guidance.</p>
        <div class="hero-actions mt-6">
          <a href={workPrismSiteUrl} target="_blank" rel="noopener noreferrer" class="button cta-secondary">Open WORK Prism Site ↗</a>
          <a {...getBookingLinkAttrs({ source: 'work-prism-cta', track: 'work-prism' })} class="button cta-primary">Start WORK Prism Inquiry</a>
          <button type="button" class="button cta-secondary is-disabled" aria-disabled="true">Schedule a Call</button>
          <a href="/launchpad" data-transition-link class="button cta-secondary">Need Startup Launch Instead?</a>
        </div>
      </div>
    </section>
  </div>
</Base>

---
import Base from '@/layouts/Base.astro';
import RevealText from '@/components/RevealText.astro';

const steps = [
  {
    label: 'Step 1',
    title: '20-Minute Call',
    detail: '$125. Vision, fit, and process alignment.'
  },
  {
    label: 'Step 2',
    title: 'Direction Review',
    detail: '5-10 days. $5,000. 3-5 strategic brand directions.'
  },
  {
    label: 'Step 3',
    title: 'Focused Exploratory',
    detail: '4-6 weeks. $50,000 + potential shared revenue structure.'
  },
  {
    label: 'Step 4',
    title: 'Asset Execution',
    detail: 'Production and rollout, with out-of-scope approval controls.'
  },
  {
    label: 'Step 5',
    title: 'Ongoing Oversight',
    detail: 'Flex Chief Brand Officer model + WORK & Friends support.'
  }
];

const prep = [
  'Are you an individual founder, partners, or an investment group?',
  'Do you already have a product or service concept?',
  'What category are you entering?',
  'What does success look like in 12 months?',
  'What is your current knowledge of branding?'
];

const startupOfferings = [
  {
    title: 'Startup Foundation Sprint',
    detail: 'Positioning, naming direction, core identity system, and launch narrative.'
  },
  {
    title: 'Go-To-Market Build',
    detail: 'Website, key collateral, social starter system, and launch content stack.'
  },
  {
    title: 'Founder System Retainer',
    detail: 'Post-launch support for messaging, priorities, and brand-system decisions.'
  }
];
---

<Base title="Launchpad | WORK Labs">
  <div class="section-shell">
    <section class="section-block two-col">
      <div>
        <div class="kicker"><span class="section-number">01 Launchpad Program</span><span>By WORK Labs</span></div>
        <RevealText as="h1" variant="title" class="route-title">Startup Launch Program</RevealText>
      </div>
      <RevealText as="p" variant="para" class="text-sm max-w-md">
        A structured program for startups to go from concept to launch-ready brand, product story, and execution plan with senior WORK Labs leadership.
        This is one package inside the broader WORK Labs offerings.
      </RevealText>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">02 Startup Outputs</span><span>Core Build Set</span></div>
      <RevealText as="p" variant="para" class="text-sm uppercase tracking-[0.12em]">
        Positioning · Naming · Packaging · Identity · Website · Social Content · Launch Support
      </RevealText>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">03 Launchpad Offerings</span><span>For Startup Teams</span></div>
      <div class="data-grid">
        {startupOfferings.map((item, idx) => (
          <article class="data-cell">
            <p class="text-xs uppercase tracking-[0.12em] text-slate">Offer {String(idx + 1).padStart(2, '0')}</p>
            <h3 class="mt-2 text-base">{item.title}</h3>
            <p class="text-sm mt-2">{item.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">04 Program Structure</span><span>Step-by-Step</span></div>
      <div class="data-grid">
        {steps.map((step) => (
          <article class="data-cell">
            <p class="text-xs uppercase tracking-[0.12em] text-slate">{step.label}</p>
            <h3 class="mt-2 text-base">{step.title}</h3>
            <p class="text-sm mt-2">{step.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section-block two-col">
      <div>
        <div class="kicker"><span class="section-number">05 Founder Fit</span><span>Qualification</span></div>
        <div class="data-grid">
          {prep.map((item, i) => (
            <article class="data-cell">
              <p class="text-xs uppercase tracking-[0.12em] text-slate">Q{String(i + 1).padStart(2, '0')}</p>
              <p class="text-sm mt-2">{item}</p>
            </article>
          ))}
        </div>
      </div>
      <div class="text-sm">
        <p class="uppercase tracking-[0.12em] text-slate">Call Format</p>
        <p class="mt-3">WORK Session / 20 minutes / Zoom / $125</p>
        <p class="mt-3">Topics: launch planning, rebrand constraints, critical-stage thinking, and execution pathway.</p>
        <div class="hero-actions mt-6">
          <a href="/model" data-transition-link class="button cta-secondary">See All Offerings</a>
          <a href="/contact" data-transition-link class="button cta-primary">Apply to Launchpad</a>
          <a href="/work-hq" data-transition-link class="button cta-secondary">Need Ongoing Consulting?</a>
        </div>
      </div>
    </section>
  </div>
</Base>

---
import Base from '@/layouts/Base.astro';
import RevealText from '@/components/RevealText.astro';
---

<Base title="Contact | WORK Labs">
  <div class="section-shell">
    <section class="section-block">
      <div class="kicker"><span class="section-number">01 Contact</span><span>Partner Inquiry</span></div>
      <RevealText as="h1" variant="title" class="route-title">Partner Inquiry</RevealText>
      <RevealText as="p" variant="para" class="mt-5 max-w-2xl text-sm">
        Share your current stage, constraints, and desired outcomes. Note whether this is for WORK Labs execution, Launchpad startup program, or WORK-HQ retainers.
      </RevealText>
    </section>

    <section class="section-block two-col">
      <div>
        <div class="kicker"><span class="section-number">02 Email</span><span>Primary</span></div>
        <p class="display-title text-[clamp(1.7rem,4vw,3.1rem)]">partners@worklabs.com</p>
      </div>
      <div class="text-sm">
        <p class="uppercase tracking-[0.12em] text-slate">Include</p>
        <p class="mt-3">Company, context, timeline, and what success looks like by quarter.</p>
      </div>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">03 Brief</span><span>Submit Details</span></div>
      <form class="contact-form" method="POST" action="mailto:partners@worklabs.com" enctype="text/plain">
        <label class="quick-field">
          <span>Company / Project</span>
          <input id="contact-company" name="company" type="text" required />
        </label>
        <label class="quick-field">
          <span>Primary Goal</span>
          <input id="contact-goal" name="goal" type="text" required />
        </label>
        <label class="quick-field">
          <span>Inquiry Type</span>
          <input id="contact-track" name="track" type="text" placeholder="WORK Labs / Launchpad / WORK-HQ" />
        </label>
        <label class="quick-field">
          <span>Timeline</span>
          <input id="contact-timeline" name="timeline" type="text" required />
        </label>
        <label class="quick-field quick-field-full">
          <span>Email</span>
          <input id="contact-email" name="email" type="email" placeholder="you@company.com" required />
        </label>
        <label class="quick-field quick-field-full">
          <span>Context</span>
          <textarea id="contact-context" name="context" rows="5" placeholder="Current challenge, constraints, and desired outcomes."></textarea>
        </label>
        <button class="button cta-primary" type="submit">Send Partner Inquiry</button>
      </form>
      <p class="form-note mt-4">If mail client submit is blocked, email partners@worklabs.com directly with the same fields.</p>
    </section>
  </div>
  <script type="module">
    const params = new URLSearchParams(window.location.search);
    const map = [
      ['company', 'contact-company'],
      ['goal', 'contact-goal'],
      ['timeline', 'contact-timeline'],
      ['track', 'contact-track']
    ];

    map.forEach(([param, id]) => {
      const el = document.getElementById(id);
      const value = params.get(param);
      if (el && value) el.value = value;
    });
  </script>
</Base>

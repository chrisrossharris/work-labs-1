---
import Base from '@/layouts/Base.astro';
import RevealText from '@/components/RevealText.astro';
import { ventures } from '@/data/ventures';
import { getBookingLinkAttrs } from '@/data/booking';
---

<Base title="WORK Labs | Execution Arm">
  <div class="section-shell">
    <section class="section-block">
      <div class="kicker">
        <span class="section-number">01 WORK Labs</span>
        <span>Execution Arm / WORK Division</span>
      </div>
      <RevealText as="h1" variant="title" class="hero-title">
        WORK Labs<br />Builds It Through
      </RevealText>
      <RevealText as="p" variant="para" class="mt-6 max-w-3xl text-sm uppercase tracking-[0.14em]">
        Best-of-class agency evolved for entrepreneur audiences: execution offerings, launch programs, and strategic retainers.
      </RevealText>
      <div class="hero-actions mt-6">
        <a {...getBookingLinkAttrs({ source: 'home-hero', track: 'work-labs' })} class="button cta-primary">Start a Project</a>
        <button type="button" class="button cta-secondary is-disabled" aria-disabled="true">Schedule a Call</button>
        <a href="/model" data-transition-link class="button cta-secondary">View Offerings</a>
        <a href="/portfolio" data-transition-link class="button cta-secondary">View Portfolio</a>
        <a href="/launchpad" data-transition-link class="button cta-secondary">Launchpad Program</a>
        <a href="/work-prism" data-transition-link class="button cta-secondary">WORK Prism Retainers</a>
      </div>
      <div class="fit-strip mt-6">
        <p>Best fit: teams that need senior-level execution without agency overhead.</p>
      </div>
    </section>

    <section class="section-block two-col">
      <div>
        <div class="kicker"><span class="section-number">02 Why WORK Labs</span><span>Experience + Reputation</span></div>
        <RevealText as="h2" variant="title" class="display-title">Built on decades of high-stakes brand work.</RevealText>
      </div>
      <RevealText as="p" variant="para" class="text-sm max-w-md">
        Since 1994, WORK has supported agencies and direct clients on complex assignments. Today, WORK Labs is the operational core that turns strategy into finished assets, launches, and measurable business outcomes.
      </RevealText>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">03 What We Deliver</span><span>Modernized Offering</span></div>
      <div class="data-grid">
        <a class="data-cell" href="/process/execution-services" data-transition-link><p class="text-xs uppercase tracking-[0.12em] text-slate">01</p><h3 class="mt-1 text-base">Brand Systems</h3><p class="text-sm">Positioning, identity, messaging architecture, and launch-ready brand assets.</p></a>
        <a class="data-cell" href="/process/streamlined-process" data-transition-link><p class="text-xs uppercase tracking-[0.12em] text-slate">02</p><h3 class="mt-1 text-base">Execution Ops</h3><p class="text-sm">Web, content, production, rollout planning, and implementation management.</p></a>
        <a class="data-cell" href="/process/flexible-team" data-transition-link><p class="text-xs uppercase tracking-[0.12em] text-slate">03</p><h3 class="mt-1 text-base">Flex Leadership</h3><p class="text-sm">Fractional creative/brand leadership at critical moments in the business lifecycle.</p></a>
      </div>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">04 Process</span><span>Streamlined, Not Overprocessed</span></div>
      <RevealText as="p" variant="para" class="text-sm uppercase tracking-[0.12em]">
        Discover → Define → Design → Develop → Deploy → Measure → Refine
      </RevealText>
      <div class="data-grid mt-4">
        <article class="data-cell"><p class="text-sm">Clear scope and faster decisions.</p></article>
        <article class="data-cell"><p class="text-sm">Transform-first production for performance.</p></article>
        <article class="data-cell"><p class="text-sm">No excess layers. No hidden process drag.</p></article>
      </div>
    </section>

    <section class="section-block two-col">
      <div>
        <div class="kicker"><span class="section-number">05 Team Model</span><span>Best of Class Associates</span></div>
        <RevealText as="h2" variant="title" class="display-title">Core studio + WORK & Friends network.</RevealText>
      </div>
      <div class="text-sm">
        <p>WORK Labs leads strategy and execution from the center.</p>
        <p class="mt-3">When needed, we pull specialized associates into the build: design, digital, content, production, media, and category experts.</p>
        <p class="mt-3">You get flexible senior capacity without carrying full-time overhead.</p>
      </div>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">06 Portfolio</span><span>Simplified View</span></div>
      <div class="data-grid">
        {ventures.slice(0, 3).map((venture) => (
          <a class="data-cell" href={`/portfolio/${venture.slug}`} data-transition-link data-flip-source={`venture-${venture.slug}`}>
            <p class="text-xs uppercase tracking-[0.12em] text-slate">{venture.index}</p>
            <h3 class="mt-2 text-base">{venture.name}</h3>
            <p class="text-sm mt-2">{venture.focus}</p>
            <p class="text-xs uppercase tracking-[0.1em] text-slate mt-3">{venture.metric}</p>
          </a>
        ))}
      </div>
      <div class="hero-actions mt-6">
        <a href="/portfolio" data-transition-link class="button cta-secondary">Open Full Portfolio</a>
        <a href="/testimonials" data-transition-link class="button cta-secondary">Read Testimonials</a>
      </div>
    </section>

    <section class="section-block">
      <div>
        <div class="kicker"><span class="section-number">07 Program Tracks</span><span>Choose The Right Path</span></div>
      </div>
      <div class="data-grid">
        <article class="data-cell">
          <p class="text-xs uppercase tracking-[0.12em] text-slate">Track 01</p>
          <h3 class="mt-2 text-base">WORK Launchpad Program</h3>
          <p class="text-sm mt-2">For startups building from concept to launch with a structured WORK Labs process.</p>
          <div class="hero-actions mt-4">
            <a href="/launchpad" data-transition-link class="button cta-secondary">Go to Launchpad</a>
          </div>
        </article>
        <article class="data-cell">
          <p class="text-xs uppercase tracking-[0.12em] text-slate">Track 02</p>
          <h3 class="mt-2 text-base">WORK Prism</h3>
          <p class="text-sm mt-2">Separate consulting track for system-thinking leadership and ongoing retainer support.</p>
          <div class="hero-actions mt-4">
            <a href="/work-prism" data-transition-link class="button cta-secondary">Go to WORK Prism</a>
          </div>
        </article>
      </div>
    </section>

    <section class="section-block two-col">
      <div>
        <div class="kicker"><span class="section-number">08 Next Step</span><span>Primary Action</span></div>
        <RevealText as="h2" variant="title" class="display-title">Send a quick brief. We’ll scope the build.</RevealText>
      </div>
      <div>
        <form class="quick-brief" method="GET" action="/contact" data-transition-form>
          <input type="hidden" name="source" value="work-labs-home" />
          <label class="quick-field">
            <span>Company / Project</span>
            <input name="company" type="text" required />
          </label>
          <label class="quick-field">
            <span>Primary Need</span>
            <input name="goal" type="text" required />
          </label>
          <label class="quick-field">
            <span>Timeline</span>
            <input name="timeline" type="text" placeholder="e.g. next 90 days" required />
          </label>
          <button class="button cta-primary" type="submit">Send Quick Brief</button>
        </form>
      </div>
    </section>
  </div>
</Base>

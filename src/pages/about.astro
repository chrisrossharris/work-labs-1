---
import Base from '@/layouts/Base.astro';
import RevealText from '@/components/RevealText.astro';
---

<Base title="About | WORK Launch Pad">
  <div class="section-shell">
    <section class="section-block">
      <div class="kicker"><span class="section-number">01 About</span><span>Always Thinking</span></div>
      <RevealText as="h1" variant="title" class="route-title" flipKey="about-title">About / Always Thinking</RevealText>
      <RevealText as="p" variant="para" class="mt-6 max-w-2xl text-sm">
        Cabell Harris leads WORK Launch Pad as a creative venture studio built for operators who treat brand as financial infrastructure.
      </RevealText>
    </section>

    <section class="section-block two-col">
      <div>
        <div class="kicker"><span class="section-number">02 Philosophy</span><span>Collaborative Intelligence</span></div>
        <RevealText as="h2" variant="title" class="display-title">AI + HI = CI</RevealText>
      </div>
      <RevealText as="p" variant="para" class="text-sm max-w-md">
        Human taste and machine leverage are only useful when integrated into clear decisions. CI is the operating standard across strategy, design, and execution.
      </RevealText>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">03 Bio Notes</span><span>Builder, Not Bureaucrat</span></div>
      <div class="data-grid">
        <article class="data-cell"><p class="text-xs uppercase tracking-[0.12em] text-slate">01</p><p class="text-sm">Creative strategist with venture-building focus.</p></article>
        <article class="data-cell"><p class="text-xs uppercase tracking-[0.12em] text-slate">02</p><p class="text-sm">Builds execution systems that survive scale and turnover.</p></article>
        <article class="data-cell"><p class="text-xs uppercase tracking-[0.12em] text-slate">03</p><p class="text-sm">Aligns teams around cost, time, and impact instead of vanity outputs.</p></article>
      </div>
    </section>
  </div>
</Base>

---
import Base from '@/layouts/Base.astro';
import RevealText from '@/components/RevealText.astro';
---

<Base title="About | WORK Labs">
  <div class="section-shell">
    <section class="section-block">
      <div class="kicker"><span class="section-number">01 About</span><span>Always Thinking</span></div>
      <RevealText as="h1" variant="title" class="route-title" flipKey="about-title">About WORK Labs</RevealText>
      <RevealText as="p" variant="para" class="mt-6 max-w-2xl text-sm">
        Founded in 1994, WORK began as a creative resource for agencies and evolved into a direct execution partner for brands, operators, and growth teams.
      </RevealText>
    </section>

    <section class="section-block two-col">
      <div>
        <div class="kicker"><span class="section-number">02 Mission</span><span>How We Work</span></div>
        <RevealText as="h2" variant="title" class="display-title">Create work we love, with people we like, in a place we want to be.</RevealText>
      </div>
      <RevealText as="p" variant="para" class="text-sm max-w-md">
        We treat execution as a strategic advantage. The objective is not more activity. The objective is better business outcomes.
      </RevealText>
    </section>

    <section class="section-block">
      <div class="kicker"><span class="section-number">03 Ecosystem</span><span>WORK Structure</span></div>
      <div class="data-grid">
        <article class="data-cell"><p class="text-xs uppercase tracking-[0.12em] text-slate">01</p><h3 class="mt-2 text-base">WORK Labs</h3><p class="text-sm mt-2">Studio and execution engine across planning, production, and delivery.</p></article>
        <article class="data-cell"><p class="text-xs uppercase tracking-[0.12em] text-slate">02</p><h3 class="mt-2 text-base">WORK & Friends</h3><p class="text-sm mt-2">National network of best-of-class specialists engaged when needed.</p></article>
        <article class="data-cell"><p class="text-xs uppercase tracking-[0.12em] text-slate">03</p><h3 class="mt-2 text-base">Cabell Harris</h3><p class="text-sm mt-2">Founder and strategic creative lead focused on critical-stage decision quality.</p></article>
      </div>
    </section>
  </div>
</Base>
